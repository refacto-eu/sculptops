# Database
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/sculptops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sculptops

# Auth.js
AUTH_SECRET=your-secret-here-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Encryption key for SSH private keys (32 bytes hex = 64 chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SculptOps

# Docker socket (for executing Ansible playbooks)
DOCKER_SOCKET=/var/run/docker.sock

# Ansible container image
ANSIBLE_DOCKER_IMAGE=cytopia/ansible:latest

# Docker network used by ephemeral Ansible containers. Use "host" only if you
# explicitly need host-network access from playbook runs.
ANSIBLE_DOCKER_NETWORK=bridge

# Outbound callbacks block localhost/private IP targets by default.
# Set to true only for trusted self-hosted/internal deployments.
ALLOW_PRIVATE_OUTBOUND=false
ALLOW_INSECURE_OUTBOUND_HTTP=false

# ── Community library (optional) ────────────────────────────────────────────
# Leave unset to run SculptOps without the community feature (fully supported).
# Set these if you deploy the community-api service alongside the app.
#
# COMMUNITY_API_URL=http://localhost:3001
# COMMUNITY_SUBMIT_KEY=   # must match SUBMIT_API_KEY in community-api
